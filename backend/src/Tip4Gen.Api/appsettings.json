{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.Hosting": "Information",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "WorldCup26Ir": {
    "BaseUrl": "https://worldcup26.ir",
    "LeagueId": "wc26",
    "Season": 2026,
    "TimeoutSeconds": 15
  },
  "FixturePoller": {
    "IntervalMinutes": 15,
    "ActiveWindowHours": 4,
    "LookaheadMinutes": 60,
    "StartupDelaySeconds": 5
  },
  "TeamLockJob": {
    "IntervalMinutes": 5,
    "StartupDelaySeconds": 10
  },
  "AiTippingJob": {
    "IntervalMinutes": 5,
    "StartupDelaySeconds": 15
  },
  "NotificationsJob": {
    "IntervalMinutes": 10,
    "StartupDelaySeconds": 30
  },
  "Notifications": {
    "SiteBaseUrl": "http://localhost:5173"
  },
  "Resend": {
    "BaseUrl": "https://api.resend.com",
    "FromAddress": "Tip4Gen <onboarding@resend.dev>",
    "TimeoutSeconds": 15
  }
}

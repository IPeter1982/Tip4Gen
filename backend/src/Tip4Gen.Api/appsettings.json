{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.Hosting": "Information",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "FixturePoller": {
    "IntervalMinutes": 15,
    "ActiveWindowHours": 4,
    "LookaheadMinutes": 60,
    "StartupDelaySeconds": 5
  },
  "TeamLockJob": {
    "IntervalMinutes": 5,
    "StartupDelaySeconds": 10
  },
  "AiTippingJob": {
    "IntervalMinutes": 5,
    "StartupDelaySeconds": 15
  }
}
